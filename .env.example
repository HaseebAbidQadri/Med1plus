# Copy this file to .env and fill in your actual values
# NEVER commit .env — it is git-ignored

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# App URL (change to your deployed backend URL in production)
APP_URL=http://localhost:3000

# Turso Edge SQL Database
TURSO_CONNECTION_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Admin Dashboard Auth
ADMIN_EMAIL=admin@medonepharmacy.com
ADMIN_PASSWORD=your_strong_password_here
JWT_SECRET=your_very_long_random_jwt_secret_here

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Set to "false" to run frontend (Vite) and backend (Express) as separate processes
# Set to "true" or remove this line to run them together
SERVE_FRONTEND=false
